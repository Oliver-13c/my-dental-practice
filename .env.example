# App URL – for redirect links in emails (password reset, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase – public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key-...

# Supabase – server only (NEVER prefix with NEXT_PUBLIC_)
# Get from: Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=service-role-key-...

# NextAuth – generate with: npx auth secret
# Required for JWT signing (staff authentication)
AUTH_SECRET=your-random-secret-here

# CSRF – optional extra entropy for token signing (leave empty to use AUTH_SECRET)
CSRF_SECRET=

# NextAuth credentials (no Supabase)
AUTH_ADMIN_EMAIL=admin@practice.com
AUTH_ADMIN_PASSWORD=change-me

# Resend (email)
RESEND_API_KEY=re_...

# Sentry – error monitoring & alerting
# Get DSN from: Sentry Dashboard → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX

# Sentry organisation slug (shown in your Sentry URL: sentry.io/organizations/<slug>/)
SENTRY_ORG=your-sentry-org

# Sentry project slug (shown in Sentry → Settings → Projects)
SENTRY_PROJECT=my-dental-practice

# Sentry auth token for source-map upload during CI/CD builds
# Get from: Sentry Dashboard → Settings → Auth Tokens → Create New Token
# Required scopes: project:releases, org:read
SENTRY_AUTH_TOKEN=sntrys_...

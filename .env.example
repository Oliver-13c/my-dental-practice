# Supabase – public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key-...

# Supabase – server only (NEVER prefix with NEXT_PUBLIC_)
# Get from: Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=service-role-key-...

# NextAuth – generate with: npx auth secret
# Required for JWT signing (staff authentication)
AUTH_SECRET=your-random-secret-here

# NextAuth credentials (no Supabase)
AUTH_ADMIN_EMAIL=admin@practice.com
AUTH_ADMIN_PASSWORD=change-me

# Resend (email)
RESEND_API_KEY=re_...

# Sentry – error tracking
# Get DSN from: Sentry Dashboard → Settings → Projects → <project> → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oXXX.ingest.sentry.io/YYYY
# Target environment label (e.g. development | staging | production)
NEXT_PUBLIC_APP_ENV=development
# Optional: pinned release/version string (auto-set by CI in production)
NEXT_PUBLIC_SENTRY_RELEASE=
# Required for uploading source maps to Sentry (keep server-only / CI secret)
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=my-dental-practice

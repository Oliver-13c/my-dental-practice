# Supabase – public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key-...

# Supabase – server only (NEVER prefix with NEXT_PUBLIC_)
# Get from: Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=service-role-key-...

# Resend (email)
RESEND_API_KEY=re_...

# Database (direct connection string, used by migrations / scripts)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@db.xxxx.supabase.co:5432/postgres
